library(clusterProfiler)
library(org.At.tair.db)


# 1. Ambil daftar SYMBOL, tapi pastikan tidak ada NA dan harus unik
# Kita ambil dari kolom SYMBOL yang sudah ada di tabel deg hasil merge sebelumnya
probe_list <- deg %>%
  filter(!is.na(SYMBOL) & SYMBOL != "") %>%
  pull(SYMBOL) %>%
  unique()

# Cek dulu isinya, kalau muncul nama gen (misal: CBF1, COR15A), berarti sudah benar
head(probe_list)

# 2. Konversi menggunakan bitr dengan data yang sudah bersih
# Jika SYMBOL gagal, kita akan coba pakai keytype 'PROBEID'
id_map <- tryCatch({
  bitr(probe_list,
       fromType = "SYMBOL",
       toType = "TAIR",
       OrgDb = org.At.tair.db)
}, error = function(e) {
  message("SYMBOL gagal, mencoba konversi lewat PROBEID...")
  bitr(deg$PROBEID,
       fromType = "PROBEID",
       toType = "TAIR",
       OrgDb = ath1121501.db) # Pakai library chip untuk PROBEID
})

# 3. Lihat hasilnya
head(id_map)


# 1. Gabungkan id_map (TAIR) ke tabel DEG utama
# Kita gunakan PROBEID sebagai kunci penggabung
deg_final <- deg %>%
  left_join(id_map, by = "PROBEID")

# 2. Buat daftar untuk KEGG Mapper (Top 20 UP dan Top 20 DOWN)
# Kita beri warna Merah untuk UP dan Biru untuk DOWN
kegg_input <- deg_final %>%
  filter(!is.na(TAIR)) %>%
  group_by(status) %>%
  slice_max(order_by = abs(logFC), n = 20) %>%
  mutate(kegg_line = paste(TAIR, ifelse(status == "UP", "red", "blue"))) %>%
  pull(kegg_line)

# 3. Munculkan hasilnya di Console
cat("\n--- COPY DAFTAR DI BAWAH INI KE WEBSITE KEGG MAPPER --- \n")
cat(kegg_input, sep="\n")

# 4. Simpan tabel final yang sudah ada TAIR ID-nya
write.csv(deg_final, file.path(folder_name, "Hasil_Analisis_Lengkap_Annotated.csv"), row.names = FALSE)

message("Tabel final sudah disimpan di folder Hasil_Plot_Capstone.")
