# ============================================================
# ANALISIS EKSPRESI GEN MICROARRAY + ENRICHMENT
# Dataset : GSE5620
# Organism : Arabidopsis thaliana
# Platform : Affymetrix ATH1
# Tujuan : DEG + GO + KEGG (ALL, UP, DOWN)
# Perbandingan : Shoot 0h vs Shoot 24h Cold
# ============================================================

# ================================
# A. INSTALL & LOAD PACKAGE
# ================================

#1. Install BiocManager (manajer paket Bioconductor)
if (!require("BiocManager", quietly = TRUE)) {
  install.packages("BiocManager")
}

# 2. Install paket Bioconductor (GEOquery & limma) dan Install annotation package sesuai platform
BiocManager::install(c(
  "GEOquery",
  "limma",
  "ath1121501.db",
  "org.At.tair.db",
  "clusterProfiler",
  "enrichplot"
), ask = FALSE, update = FALSE)


#3. Install paket CRAN untuk visualisasi dan manipulasi data 
install.packages(c("pheatmap","ggplot2","dplyr"))

if (!requireNamespace("umap", quietly = TRUE)) {
  install.packages("umap")
}

#4. Memanggil library 
library(GEOquery)
library(limma)
library(pheatmap)
library(ggplot2)
library(dplyr)
library(AnnotationDbi)
library(clusterProfiler)
library(enrichplot)
library(ath1121501.db)
library(org.At.tair.db)
library(umap)

# ================================
# B. DOWNLOAD DATA GEO
# ================================
library(GEOquery)

# ------------------------------------------------------------
# 2. DOWNLOAD & VALIDASI (COORDINATING COLD STRESS)
# ------------------------------------------------------------
# getGPL & AnnotGPL = FALSE agar tidak error HTTP/Timeout
gset <- getGEO("GSE5620", destdir = ".", getGPL = FALSE, AnnotGPL = FALSE)
if (class(gset) == "list") gset <- gset[[1]]

pdata <- pData(gset)

# ambil matriks ekspresi
ex <- exprs(gset)

# ================================
# C. LOG2 TRANSFORMASI
# ================================
ex <- exprs(gset)
qx <- as.numeric(quantile(ex, c(0,0.25,0.5,0.75,0.99,1), na.rm = TRUE))
LogTransform <- (qx[5] > 100) || (qx[6]-qx[1] > 50 && qx[2] > 0)

if(LogTransform){
  ex[ex <= 0] <- NA
  ex <- log2(ex)
  print("Data di-log2 transform")
} else {
  print("Data sudah dalam skala log, tidak di-transform lagi")
}

# ========================================
# METADATA
# ========================================

pdata <- pData(gset)

# lihat semua nama sampel
pdata$title



# ========================================
# FILTER SHOOTS
# ========================================
shoot_samples <- grep("Shoots", pdata$title)

gset <- gset[, shoot_samples]

ex <- ex[, shoot_samples]
pdata <- pData(gset)

dim(ex)

# ========================================
# FILTER TIME POINT
# ========================================

t0_samples <- grep("Shoots-0h_", pdata$title)
t24_samples <- grep("Shoots-24.0h_", pdata$title)

selected <- c(t0_samples, t24_samples)

gset <- gset[, selected]

ex <- ex[, selected]
pdata <- pData(gset)

pdata$title


dim(ex)
range(ex)


# ================================
# E. DEFINISI GRUP
# ================================
group <- factor(c("T0","T0","T24","T24"))

table(group)

# ================================
# F. DESAIN MATRIX
# ================================
design <- model.matrix(~0 + group)
colnames(design) <- levels(group)


# ================================
# F. ANALISIS DEG (LIMMA)
# ================================
# ================================
# DIFFERENTIAL EXPRESSION
# ================================

fit <- lmFit(ex, design)

contrast_matrix <- makeContrasts(
  T24 - T0,
  levels = design
)

fit2 <- contrasts.fit(fit, contrast_matrix)
fit2 <- eBayes(fit2)

deg <- topTable(
  fit2,
  adjust = "BH",
  number = Inf
)

write.csv(deg,"DEG_GSE5620_shoot_0h_vs_24h.csv")


# ================================
# G. ANOTASI PROBE
# ================================

# Ambil ID probe dari baris nama variabel 'deg'
probe_ids <- rownames(deg)

# Ambil anotasi dari library ath1121501.db
gene_annotation <- AnnotationDbi::select(
  ath1121501.db,
  keys = probe_ids,
  columns = c("SYMBOL","GENENAME"),
  keytype = "PROBEID"
)

# Tambahkan kolom PROBEID ke data frame 'deg' supaya bisa di-merge
deg$PROBEID <- rownames(deg)

# Gabungkan hasil DEG dengan anotasi gen
deg <- merge(
  deg,
  gene_annotation,
  by = "PROBEID",
  all.x = TRUE
)

# Cek hasil akhirnya
head(deg)

# ================================
# H. BUAT FOLDER OUTPUT
# ================================
# Pakai satu nama yang konsisten
folder_name <- "Hasil_Plot_Capstone"

if (!dir.exists(folder_name)) {
  dir.create(folder_name)
}

# ================================
# I. BOXPLOT QC
# ================================

# Kita gabungkan nama folder dan nama file pakai file.path biar aman
png(file.path(folder_name, "Boxplot.png"),
    width=2000, height=1200, res=300)

boxplot(ex,
        col=c("red", "red", "blue", "blue"), # Biar T0 dan T24 beda warna
        las=2,
        outline=FALSE,
        main="Distribusi Ekspresi (Normalized)")

dev.off()
# Kalau muncul "null device", langsung cek folder Hasil_Plot_Capstone!



# ================================
# J. UMAP (REVISI UNTUK SAMPEL KECIL)
# ================================
library(umap)

# 1. Atur konfigurasi UMAP khusus untuk sampel sedikit
custom_config <- umap.defaults
custom_config$n_neighbors <- 2 # Karena sampel kita cuma 4

# 2. Jalankan UMAP dengan konfigurasi baru
umap_input <- t(ex)
umap_result <- umap(umap_input, config = custom_config)

# 3. Buat data frame untuk plotting
umap_df <- data.frame(
  UMAP1 = umap_result$layout[,1],
  UMAP2 = umap_result$layout[,2],
  Group = group
)

# 4. Visualisasi
p_umap <- ggplot(umap_df, aes(x = UMAP1, y = UMAP2, color = Group)) +
  geom_point(size = 5) +
  geom_text(aes(label = rownames(umap_df)), vjust = -1, size = 3) + # Tambah label nama sampel
  theme_minimal() +
  labs(title = "UMAP Clustering (n_neighbors = 2)",
       x = "UMAP Dimension 1",
       y = "UMAP Dimension 2") +
  scale_color_manual(values = c("T0" = "red", "T24" = "blue"))

# 5. Simpan ke folder
ggsave(file.path("Hasil_Plot_Capstone", "UMAP.png"),
       p_umap, width = 6, height = 5, dpi = 300)

print(p_umap)


# ========================================
# J. VOLCANO PLOT (REVISI SIMPAN)
# ========================================

deg$gene <- rownames(deg)

deg$status <- "NO"
deg$status[deg$logFC > 0.5 & deg$P.Value < 0.05] <- "UP"
deg$status[deg$logFC < -0.5 & deg$P.Value < 0.05] <- "DOWN"

print("Statistik Gen:")
table(deg$status)

library(ggplot2)

# --- PERBAIKAN DI SINI: Masukkan ke variabel p_volcano ---
p_volcano <- ggplot(deg, aes(logFC, -log10(P.Value), color=status)) +
  geom_point(alpha=0.6, size=2) +
  geom_vline(xintercept = c(-0.5, 0.5), linetype = "dashed", color = "black", alpha = 0.5) +
  geom_hline(yintercept = -log10(0.05), linetype = "dashed", color = "black", alpha = 0.5) +
  theme_minimal() +
  scale_color_manual(values=c(
    "DOWN"="blue",
    "NO"="grey",
    "UP"="red"
  )) +
  labs(
    title = "Volcano Plot: Shoot 0h vs 24h",
    subtitle = "Threshold: |logFC| > 0.5 & P.Value < 0.05",
    x = "log2 Fold Change",
    y = "-log10 P-Value"
  )

# Sekarang p_volcano sudah ada, jadi ggsave & print nggak akan error lagi
ggsave(file.path("Hasil_Plot_Capstone", "Volcano.png"),
       p_volcano, width = 8, height = 6, dpi = 300)

print(p_volcano)


# ================================
# L. HEATMAP TOP GENES
# ================================

# 1. Urutkan berdasarkan P.Value (karena kita tadi pakai P.Value biasa)
# Kalau mau tetap pakai adj.P.Val juga boleh, tapi pastikan variabelnya ada
deg_sorted <- deg[order(deg$P.Value), ]

# 2. Ambil 50 gen teratas
top50 <- head(deg_sorted, 50)

# 3. Ambil data ekspresi hanya untuk 50 gen tersebut
# Kita gunakan PROBEID sebagai index untuk mengambil baris di 'ex'
mat_heatmap <- ex[top50$PROBEID, ]

# 4. Ganti nama baris di matriks dengan SYMBOL gen (biar heatmap-nya bisa dibaca)
# Kalau SYMBOL-nya kosong (NA), tetap pakai PROBEID
rownames(mat_heatmap) <- ifelse(!is.na(top50$SYMBOL), top50$SYMBOL, top50$PROBEID)

# 5. Gambar Heatmap
library(pheatmap)
pheatmap(mat_heatmap,
         scale = "row", # Penting! Supaya terlihat perbedaan ekspresi per gen
         clustering_distance_rows = "euclidean",
         clustering_distance_cols = "euclidean",
         main = "Top 50 Differentially Expressed Genes",
         color = colorRampPalette(c("blue", "white", "red"))(100),
         filename = file.path("Hasil_Plot_Capstone", "Heatmap.png")) # Simpan ke folder yang benar

# ========================================
# K. ENRICHMENT ALL GENES (REVISI)
# ========================================

# 1. Gunakan variabel 'deg' (hasil dari merge di bagian G)
# Filter p-value < 0.05 agar data yang diuji cukup banyak
deg_all_list <- deg %>%
  filter(P.Value < 0.05 & !is.na(SYMBOL)) %>%
  pull(SYMBOL) %>%
  unique()

# 2. Konversi ke ENTREZID (WAJIB pakai org.At.tair.db untuk Arabidopsis)
entrez_all <- bitr(deg_all_list,
                   fromType = "SYMBOL",
                   toType = "ENTREZID",
                   OrgDb = org.At.tair.db)

# GO Enrichment - ALL
ego_all <- enrichGO(
  gene = entrez_all$ENTREZID,
  OrgDb = org.At.tair.db,
  ont = "BP",
  pvalueCutoff = 0.05,
  readable = TRUE
)

p1 <- dotplot(ego_all, showCategory = 15) + ggtitle("GO BP - ALL DEG (Arabidopsis)")
ggsave(file.path("Hasil_Plot_Capstone", "GO_BP_All_DEG.png"), plot = p1, width = 8, height = 6, dpi = 300)

# KEGG Enrichment - ALL (Organism 'ath' untuk Arabidopsis)
ekegg_all <- enrichKEGG(
  gene = entrez_all$ENTREZID,
  organism = "ath",
  pvalueCutoff = 0.05
)

# Hanya jalankan setReadable jika ada hasil KEGG
if(!is.null(ekegg_all)) {
  ekegg_all <- setReadable(ekegg_all, OrgDb = org.At.tair.db, keyType="ENTREZID")
  p2 <- dotplot(ekegg_all, showCategory = 15) + ggtitle("KEGG - ALL DEG")
  ggsave(file.path("Hasil_Plot_Capstone", "KEGG_All_DEG.png"), plot = p2, width = 8, height = 6, dpi = 300)
}

# ========================================
# L. ENRICHMENT UP vs DOWN (REVISI)
# ========================================

# Filter UP dan DOWN sesuai status yang sudah kita buat di Volcano Plot
deg_up_list <- deg %>% filter(status == "UP" & !is.na(SYMBOL)) %>% pull(SYMBOL) %>% unique()
deg_down_list <- deg %>% filter(status == "DOWN" & !is.na(SYMBOL)) %>% pull(SYMBOL) %>% unique()

# Konversi ENTREZ
entrez_up <- bitr(deg_up_list, fromType = "SYMBOL", toType = "ENTREZID", OrgDb = org.At.tair.db)
entrez_down <- bitr(deg_down_list, fromType = "SYMBOL", toType = "ENTREZID", OrgDb = org.At.tair.db)

# GO UP
ego_up <- enrichGO(entrez_up$ENTREZID, OrgDb = org.At.tair.db, ont = "BP", pvalueCutoff = 0.05, readable = TRUE)
p3 <- dotplot(ego_up, showCategory = 15) + ggtitle("GO BP - UP Genes")
ggsave(file.path("Hasil_Plot_Capstone", "GO_BP_UP_DEG.png"), plot = p3, width = 8, height = 6, dpi = 300)

# GO DOWN
ego_down <- enrichGO(entrez_down$ENTREZID, OrgDb = org.At.tair.db, ont = "BP", pvalueCutoff = 0.05, readable = TRUE)
p4 <- dotplot(ego_down, showCategory = 15) + ggtitle("GO BP - DOWN Genes")
ggsave(file.path("Hasil_Plot_Capstone", "GO_BP_DOWN_DEG.png"), plot = p4, width = 8, height = 6, dpi = 300)


# ========================================
# K. ENRICHMENT ALL GENES (GO & KEGG)
# ========================================

